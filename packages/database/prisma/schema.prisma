generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum DocumentStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum ProcessingJobStatus {
  PENDING
  QUEUED
  PROCESSING
  RETRY_SCHEDULED
  COMPLETED
  DEAD_LETTERED
}

enum ProcessingAttemptStatus {
  STARTED
  COMPLETED
  FAILED
}

model Document {
  id               String            @id @default(uuid()) @db.Uuid
  originalFilename String
  mimeType         String
  sizeBytes        BigInt
  storageKey       String            @unique
  status           DocumentStatus    @default(QUEUED)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  completedAt      DateTime?
  processingJob    ProcessingJob?
  analysis         DocumentAnalysis?
}

model ProcessingJob {
  id              String                 @id @default(uuid()) @db.Uuid
  documentId      String                 @unique @db.Uuid
  status          ProcessingJobStatus    @default(PENDING)
  attemptCount    Int                    @default(0)
  nextRetryAt     DateTime?
  leaseExpiresAt  DateTime?
  lastErrorCode   String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  document        Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  attempts        ProcessingAttempt[]

  @@index([status, nextRetryAt])
}

model ProcessingAttempt {
  id              String                  @id @default(uuid()) @db.Uuid
  processingJobId String                  @db.Uuid
  attemptNumber   Int
  status          ProcessingAttemptStatus @default(STARTED)
  startedAt       DateTime                @default(now())
  finishedAt      DateTime?
  errorCode       String?
  processingJob   ProcessingJob           @relation(fields: [processingJobId], references: [id], onDelete: Cascade)

  @@unique([processingJobId, attemptNumber])
}

model DocumentAnalysis {
  id           String   @id @default(uuid()) @db.Uuid
  documentId   String   @unique @db.Uuid
  summary      String   @db.Text
  category     String
  confidence   Float
  providerName String
  modelVersion String?
  createdAt    DateTime @default(now())
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}
